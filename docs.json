        "groups": [
          {
            "group": "Feedback Intelligence",
            "pages": [
              "product/feedback-hub",
              "product/auto-tagging",
              "product/sentiment-analysis",
              "product/trending-topics",
              "product/insight-explorer"
            ]
          },
          {
            "group": "AI Features",
            "pages": [
              "product/hey-syncly",
              "product/smart-brief",
              "product/cross-analysis"
            ]
          },
          {
            "group": "Dashboards & Reports",
            "pages": [
              "product/dashboards",
              "product/reports",
              "product/automated-workflows"
            ]
          },
          {
            "group": "Syncly Social",
            "pages": [
              "product/social/overview",
              "product/social/social-listening",
              "product/social/creator-discovery",
              "product/social/competitive-analysis",
              "product/social/campaign-tracking"
            ]
          }
        ]
      },
      {
        "tab": "Help & Support",
        "groups": [
          {
            "group": "Troubleshooting",
            "pages": [
              "support/faq",
              "support/troubleshooting",
              "support/contact"
            ]
          },
          {
            "group": "Account & Data",
            "pages": [
              "support/data-privacy",
              "support/export-data",
              "support/security"
            ]
          }
