{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "willow",
  "name": "Syncly",
  "description": "AI-powered customer intelligence suite — centralize feedback, surface insights, and grow faster.",
  "colors": {
    "primary": "#5d47c0",
    "light": "#ab59a3",
    "dark": "#f4eef5"
  },
  "favicon": "/favicon.ico",
