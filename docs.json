    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Account Setup",
            "pages": [
              "getting-started/create-account",
              "getting-started/workspace",
              "getting-started/invite-team",
              "getting-started/plans-billing"
            ]
          },
          {
            "group": "Connecting Data",
            "pages": [
              "getting-started/integrations-overview",
              "getting-started/connect-support-tools",
              "getting-started/connect-crm",
              "getting-started/connect-surveys",
              "getting-started/connect-social",
              "getting-started/import-csv"
            ]
          }
        ]
      },
      {
